  "devDependencies": {
    "@pdv/eslint": "workspace:*",
    "@pdv/http": "workspace:*",
    "@pdv/errors": "workspace:*",
    "@pdv/prettier": "workspace:*",
    "@pdv/typescript": "workspace:*",
    "@types/bun": "latest",
    "axios": "^1.13.6",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^10.6.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
