# Server
HTTP_ADDRESS=":8080"
APP_ENV=development

# PostgreSQL
DATABASE_URL="postgres://pdv:pdv@localhost:5432/pdv?sslmode=disable"

# Valkey (Redis-compatible) - used for caching/sessions
VALKEY_ADDR="localhost:6379"

# Postgres init (used by docker-compose only)
POSTGRES_DB=pdv
POSTGRES_USER=pdv
POSTGRES_PASSWORD=pdv
