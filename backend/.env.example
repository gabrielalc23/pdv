# ─── Application ───────────────────────────────────────────────
APP_ENV=development
HTTP_ADDRESS=":8080"
APP_PUBLIC_URL="http://localhost:5173"

# ─── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL="postgres://pdv:pdv@localhost:5432/pdv?sslmode=disable"

# ─── Valkey (Redis-compatible) ─────────────────────────────────
VALKEY_ADDR="localhost:6379"
VALKEY_PASSWORD=
VALKEY_DB=0

# ─── JWT / Access Token ────────────────────────────────────────
JWT_ISSUER="pdv-auth"
JWT_AUDIENCE="pdv-api"
JWT_ACTIVE_KEY_ID=
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEYS_DIR=
ACCESS_TOKEN_TTL=5m
JWT_CLOCK_SKEW=30s

# ─── Session / Refresh Token ───────────────────────────────────
REFRESH_IDLE_TTL=720h
SESSION_ABSOLUTE_TTL=2160h

# ─── Secrets (base64 encoded, at least 32 bytes decoded) ──────
AUTH_TOKEN_HASH_KEY=
AUTH_CSRF_SECRET=
RATE_LIMIT_KEY_SECRET=

# ─── Auth Feature Flags ────────────────────────────────────────
AUTH_REGISTRATION_ENABLED=true
AUTH_REQUIRE_VERIFIED_EMAIL=false
AUTH_ALLOW_EPHEMERAL_DEV_KEY=false
AUTH_TENANT_CREATION_ENABLED=true

# ─── Cookies ───────────────────────────────────────────────────
COOKIE_SECURE=
COOKIE_SAME_SITE=Lax
COOKIE_REFRESH_NAME=
COOKIE_CSRF_NAME=

# ─── Network ───────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:4173"
TRUSTED_PROXY_CIDRS=

# ─── Password (Argon2id) ───────────────────────────────────────
PASSWORD_ARGON2_MEMORY_KIB=65536
PASSWORD_ARGON2_ITERATIONS=3
PASSWORD_ARGON2_PARALLELISM=1
PASSWORD_BLOCKLIST_PATH=

# ─── Mail ──────────────────────────────────────────────────────
MAIL_DRIVER=log
MAIL_FROM="noreply@pdv.local"
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true

# ─── Postgres init (used by docker-compose only) ───────────────
POSTGRES_DB=pdv
POSTGRES_USER=pdv
POSTGRES_PASSWORD=pdv
